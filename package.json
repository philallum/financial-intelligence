  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.0.1",
    "fast-check": "4.8.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "3.2.4"
