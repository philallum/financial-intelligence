# =============================================================================
# Financial Intelligence Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Data Provider API Keys ---

# Twelve Data: Primary OHLC data source (https://twelvedata.com)
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# Massive API: Fallback OHLC data source
MASSIVE_API_KEY=your_massive_api_key_here

# Alpha Vantage: Economic calendar and US10Y yield data (https://www.alphavantage.co)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Finnhub: Market news feed (https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_api_key_here

# News API: General financial news (https://newsapi.org)
NEWS_API_KEY=your_news_api_key_here

# --- Google Cloud / Vertex AI (Gemini) ---

# GCP project ID (used for Vertex AI Gemini access via Application Default Credentials)
GCP_PROJECT_ID=financial-intelligence-501107

# GCP region for Vertex AI (default: us-central1)
GCP_LOCATION=us-central1

# Gemini model name (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase ---

# Supabase project URL (e.g., https://your-project.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous key (safe for client-side, row-level security enforced)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key (server-side only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase direct database URL (for CLI migrations and psql)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# URL-encode special characters in password ($ → %24, # → %23, etc.)
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# --- RapidAPI ---

# RapidAPI proxy secret (validates requests originating from RapidAPI marketplace)
# Obtain from RapidAPI Provider Dashboard → Security → Proxy Secret
RAPIDAPI_PROXY_SECRET=your_rapidapi_proxy_secret_here

# --- Cloud Run ---

# Server port (Cloud Run sets this automatically; default 8080)
PORT=8080

# Node environment: development | production | test
NODE_ENV=development
